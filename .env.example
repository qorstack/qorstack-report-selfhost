# Qorstack Report - copy to .env and fill in your values

# Admin account created on first startup
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# PostgreSQL
DB_PASSWORD=your-strong-db-password

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret-here

# JWT and encryption (lengths are enforced — keep them exact)
JWT_KEY=change-me-jwt-signing-key-at-least-32-chars
ENCRYPTION_KEY=change-me-encryption-key-32char!
ENCRYPTION_IV=change-me-iv-16!

# Optional: browser-facing URLs when not using localhost
# API_URL=http://localhost:8080
# CORS_ORIGINS=http://localhost:3000
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Optional: expose frontend on a different host port
# FRONTEND_PORT=3000

# Optional: external PostgreSQL
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_NAME=qorstack_report
# DB_USER=postgres

# Optional: external MinIO
# MINIO_ENDPOINT=your-minio-host:9000
# MINIO_USE_SSL=false
